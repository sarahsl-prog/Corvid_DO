# ═══════════════════════════════════════════════════════════════════════════
# Corvid Threat Intelligence Platform - Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in your actual API keys in the .env file
#   3. Never commit the .env file to version control
#
# All configuration uses the CORVID_ prefix for environment variables.
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# Database Configuration
# ───────────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (async driver required)
# Default works with docker-compose.yml
CORVID_DATABASE_URL=postgresql+asyncpg://corvid:corvid@localhost:5432/corvid

# ───────────────────────────────────────────────────────────────────────────
# Redis Configuration (Task Queue + Caching)
# ───────────────────────────────────────────────────────────────────────────
CORVID_REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────────────────────
# API Server Settings
# ───────────────────────────────────────────────────────────────────────────
CORVID_API_HOST=0.0.0.0
CORVID_API_PORT=8000

# Debug mode: enables SQL query logging and verbose output
# ⚠️  MUST be 'false' in production for security and performance
CORVID_DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
CORVID_LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────────────────────
# Gradient AI Configuration (REQUIRED)
# ───────────────────────────────────────────────────────────────────────────
# Get your API key from: https://gradient.ai/dashboard
# Required for agent functionality - app will not start without this
CORVID_GRADIENT_API_KEY=your-gradient-api-key-here

# Knowledge base ID for RAG functionality (optional)
# Create a KB at: https://gradient.ai/knowledge-bases
CORVID_GRADIENT_KB_ID=

# Gradient AI model for agent inference
# Options: gradient-large, gradient-base
CORVID_GRADIENT_MODEL=gradient-large

# Custom Gradient KB URL (optional, leave empty for default)
# CORVID_GRADIENT_KB_URL=

# ───────────────────────────────────────────────────────────────────────────
# External Threat Intelligence API Keys (OPTIONAL)
# ───────────────────────────────────────────────────────────────────────────

# AbuseIPDB - IP address reputation and abuse reports
# Free tier: 1,000 requests/day
# Get key at: https://www.abuseipdb.com/api
CORVID_ABUSEIPDB_API_KEY=

# NVD (National Vulnerability Database) - CVE information
# Without key: 5 requests per 30 seconds
# With key: 50 requests per 30 seconds
# Get key at: https://nvd.nist.gov/developers/request-an-api-key
CORVID_NVD_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# Performance Tuning (OPTIONAL - has sensible defaults)
# ───────────────────────────────────────────────────────────────────────────

# Maximum concurrent enrichment tasks (1-50)
# Increase if you have high API rate limits
# CORVID_MAX_CONCURRENT_ENRICHMENTS=5

# Timeout for agent analysis operations in seconds (5-300)
# CORVID_AGENT_TIMEOUT_SECONDS=30

# Cache TTL for enrichment results in hours (1-168)
# CORVID_ENRICHMENT_CACHE_TTL_HOURS=24

